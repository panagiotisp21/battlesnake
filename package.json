{
  "name": "starter-snake-javascript",
  "version": "1.0.0",
  "author": "BattlesnakeOfficial",
  "description": "An official Battlesnake template written in JavaScript. Get started at play.battlesnake.com.",
  "license": "MIT",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --forceExit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BattlesnakeOfficial/starter-snake-javascript.git"
  },
  "dependencies": {
    "express": "^4.20.0",
    "starter-snake-javascript": "file:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "collectCoverage": true,
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 50,
        "lines": 50,
        "statements": 50
      }
    }
  }
}
